# ------------------------------------------------------------------
# Módulo 2 — Automação de Documentos  /  Módulo 3 — Análise de Dados
# ------------------------------------------------------------------

# Ambiente virtual
.venv/
venv/
env/

# Cache e artefatos do Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Saídas geradas pelos scripts (refeitas a cada execução).
# Ignoramos o CONTEÚDO, mas mantemos os .gitkeep para preservar as pastas.

# Módulo 2 (Automação de Documentos)
saida/modulo2/*.xlsx
saida/modulo2/oficios/*
saida/modulo2/pdfs/*
!saida/modulo2/.gitkeep
!saida/modulo2/oficios/.gitkeep
!saida/modulo2/pdfs/.gitkeep

# Módulo 3 (Análise de Dados)
saida/modulo3/graficos/*
saida/modulo3/*.pdf
!saida/modulo3/.gitkeep
!saida/modulo3/graficos/.gitkeep

# Arquivos temporários do Office (abrir um .docx/.xlsx gera estes)
~$*

# Editores / sistema operacional
.vscode/
.idea/
.DS_Store
Thumbs.db